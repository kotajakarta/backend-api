# DATABASE_URL: Required for Prisma database connection (PostgreSQL).
DATABASE_URL="postgresql://user:password@localhost:5432/edaimi"

# JWT_SECRET: Secret key for JWT token signing. Change this in production!
JWT_SECRET="change-me-in-production"

# PORT: Port for the backend API server.
PORT=8080

# API_PREFIX: Global API route prefix.
API_PREFIX="api/v1"

# CORS_ORIGINS: Comma-separated list of allowed origins. Use * for all (not recommended in production).
CORS_ORIGINS="http://localhost:3000,https://domainku.com"


# Mengaktifkan/menonaktifkan dokumentasi API Swagger. (Default: true di development, false di production)
# ENABLE_SWAGGER="false"
