model Kamar {
  id   String @id @default(uuid())
  name String

  @@map("kamar")
  @@schema("pesantren")
}

model GrupDaimi {
  id                 String               @id @default(uuid())
  name               String
  jenis              String?
  ketuaId            String?              @map("ketua_id")
  ketua              Staff?               @relation("GrupDaimiKetua", fields: [ketuaId], references: [id])
  staff              Staff[]
  keaktifanMapelGrup KeaktifanMapelGrup[]
  dataDaimi          DataDaimi[]
  kelasDaimi         KelasDaimi[]

  @@map("grup_daimi")
  @@schema("pesantren")
}

model KelasDaimi {
  id        String      @id @default(uuid())
  name      String
  grupId    String      @map("grup_id")
  wilayahId String?     @map("wilayah_id")
  cabangId  String?     @map("cabang_id")
  dataDaimi DataDaimi[]
  cabang    Cabang?     @relation(fields: [cabangId], references: [id])
  grup      GrupDaimi   @relation(fields: [grupId], references: [id], onDelete: Cascade)
  wilayah   Wilayah?    @relation(fields: [wilayahId], references: [id])

  @@map("kelas_daimi")
  @@schema("pesantren")
}

model DataDaimi {
  id        String      @id @default(uuid())
  studentId String      @unique @map("student_id")
  grupId    String?     @map("grup_id")
  kelasId   String?     @map("kelas_id")
  nis       String?     @map("nis")
  grup      GrupDaimi?  @relation(fields: [grupId], references: [id])
  kelas     KelasDaimi? @relation(fields: [kelasId], references: [id])
  student   Student     @relation(fields: [studentId], references: [id])

  @@map("data_daimi")
  @@schema("pesantren")
}

model NilaiKitab {
  id    String @id @default(uuid())
  score Float

  @@map("nilai_kitab")
  @@schema("pesantren")
}
