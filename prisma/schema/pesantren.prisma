model Kamar {
  id   String @id @default(uuid())
  name String

  @@map("kamar")
  @@schema("pesantren")
}

model GrupDaimi {
  id                 String               @id @default(uuid())
  name               String
  dataDaimi          DataDaimi[]
  staff              Staff[]
  kelasDaimi         KelasDaimi[]
  keaktifanMapelGrup KeaktifanMapelGrup[]

  @@map("grup_daimi")
  @@schema("pesantren")
}

model KelasDaimi {
  id        String      @id @default(uuid())
  name      String
  grupId    String      @map("grup_id")
  grup      GrupDaimi   @relation(fields: [grupId], references: [id], onDelete: Cascade)
  wilayahId String?     @map("wilayah_id")
  wilayah   Wilayah?    @relation(fields: [wilayahId], references: [id], onDelete: SetNull)
  cabangId  String?     @map("cabang_id")
  cabang    Cabang?     @relation(fields: [cabangId], references: [id], onDelete: SetNull)
  dataDaimi DataDaimi[]

  @@map("kelas_daimi")
  @@schema("pesantren")
}

model DataDaimi {
  id        String      @id @default(uuid())
  studentId String      @unique @map("student_id")
  student   Student     @relation(fields: [studentId], references: [id])
  grupId    String?     @map("grup_id")
  grup      GrupDaimi?  @relation(fields: [grupId], references: [id])
  kelasId   String?     @map("kelas_id")
  kelas     KelasDaimi? @relation(fields: [kelasId], references: [id])
  nis       String?     @map("nis")

  @@map("data_daimi")
  @@schema("pesantren")
}

model NilaiKitab {
  id    String @id @default(uuid())
  score Float

  @@map("nilai_kitab")
  @@schema("pesantren")
}
