model SiswaFormal {
  id        String   @id @default(uuid())
  studentId String   @unique @map("student_id")
  student   Student  @relation(fields: [studentId], references: [id])
  kelasId   String?  @map("kelas_id")
  kelas     Kelas?   @relation(fields: [kelasId], references: [id])
  nis       String?  @map("nis")
  nisn      String?  @unique

  @@map("siswa_formal")
  @@schema("formal")
}

model Kelas {
  id       String  @id @default(uuid())
  name     String
  tingkat  String?
  isActive Boolean @default(true) @map("is_active")
  cabangId String? @map("cabang_id")
  cabang   Cabang? @relation(fields: [cabangId], references: [id], onDelete: SetNull)
  siswaFormal SiswaFormal[]

  @@map("kelas")
  @@schema("formal")
}

model MataPelajaran {
  id   String @id @default(uuid())
  name String

  @@map("mata_pelajaran")
  @@schema("formal")
}

model NilaiFormal {
  id          String @id @default(uuid())
  studentName String @map("student_name")
  subject     String
  score       Float

  @@map("nilai_formal")
  @@schema("formal")
}
