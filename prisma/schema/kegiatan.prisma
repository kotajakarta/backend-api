model JenisKegiatan {
  id        String             @id @default(uuid())
  nama      String             @unique
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  templates TemplateKegiatan[]

  @@map("jenis_kegiatan")
  @@schema("core")
}

model TemplateKegiatan {
  id          String            @id @default(uuid())
  judul       String
  deskripsi   String
  deadline    DateTime
  jenisId     String            @map("jenis_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  jenis       JenisKegiatan     @relation(fields: [jenisId], references: [id])
  kegiatan    Kegiatan[]
  dokumen     DokumenTemplate[]

  @@map("template_kegiatan")
  @@schema("core")
}

model DokumenTemplate {
  id         String           @id @default(uuid())
  templateId String           @map("template_id")
  filePath   String           @map("file_path")
  fileName   String           @map("file_name")
  fileType   String           @map("file_type") // DOCUMENT, PHOTO
  createdAt  DateTime         @default(now()) @map("created_at")

  template   TemplateKegiatan @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("dokumen_template")
  @@schema("core")
}

model Kegiatan {
  id                String            @id @default(uuid())
  templateId        String            @map("template_id")
  cabangId          String            @map("cabang_id")
  asramaId          String?           @map("asrama_id")
  deskripsi         String            // Deskripsi pelaksanaan oleh cabang
  
  // Konfirmasi oleh Pusat
  isConfirmed       Boolean           @default(false) @map("is_confirmed")
  confirmedAt       DateTime?         @map("confirmed_at")
  confirmedByUserId String?           @map("confirmed_by_user_id")

  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  template          TemplateKegiatan  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  cabang            Cabang            @relation(fields: [cabangId], references: [id], onDelete: Cascade)
  asrama            Ruang?            @relation(fields: [asramaId], references: [id], onDelete: SetNull)
  confirmedByUser   User?             @relation(fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  panitia           Panitia[]
  dokumen           DokumenKegiatan[]

  @@map("kegiatan")
  @@schema("core")
}

model Panitia {
  id         String   @id @default(uuid())
  kegiatanId String   @map("kegiatan_id")
  staffId    String   @map("staff_id")
  jabatan    String   // KETUA
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  kegiatan   Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)
  staff      Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("panitia")
  @@schema("core")
}

model DokumenKegiatan {
  id         String   @id @default(uuid())
  kegiatanId String   @map("kegiatan_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  fileType   String   @map("file_type") // DOCUMENT, PHOTO
  createdAt  DateTime @default(now()) @map("created_at")

  kegiatan   Kegiatan @relation(fields: [kegiatanId], references: [id], onDelete: Cascade)

  @@map("dokumen_kegiatan")
  @@schema("core")
}
