enum ProgramType {
  PELAJARAN
  UJIAN
  LAINNYA

  @@schema("absensi")
}

enum KehadiranStatus {
  HADIR
  SAKIT
  IZIN
  ALPA

  @@schema("absensi")
}

model ProgramAbsensi {
  id          String          @id @default(uuid())
  name        String
  type        ProgramType     @default(PELAJARAN)
  date        DateTime        @db.Date
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  kehadiran   Kehadiran[]
  kehadiranGuru KehadiranGuru[]

  @@map("program_absensi")
  @@schema("absensi")
}

model Kehadiran {
  id          String          @id @default(uuid())
  programId   String          @map("program_id")
  studentId   String          @map("student_id")
  cabangId    String          @map("cabang_id")
  status      KehadiranStatus @default(HADIR)
  catatan     String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  program     ProgramAbsensi  @relation(fields: [programId], references: [id], onDelete: Cascade)
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([programId, studentId])
  @@map("kehadiran")
  @@schema("absensi")
}

model KehadiranGuru {
  id          String          @id @default(uuid())
  programId   String          @map("program_id")
  guruId      String          @map("guru_id")
  cabangId    String          @map("cabang_id")
  status      KehadiranStatus @default(HADIR)
  catatan     String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  program     ProgramAbsensi  @relation(fields: [programId], references: [id], onDelete: Cascade)
  guru        Staff           @relation(fields: [guruId], references: [id], onDelete: Cascade)

  @@unique([programId, guruId])
  @@map("kehadiran_guru")
  @@schema("absensi")
}
